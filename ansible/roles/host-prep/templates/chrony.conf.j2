{# Шаблон конфига chrony — NTP-клиента для синхронизации времени.
   Jinja2: генерирует /etc/chrony/chrony.conf на каждой ноде.

   Почему chrony важен для Kubernetes:
   - etcd использует Raft consensus: лидер определяется по таймаутам.
     Расхождение часов >2–5 сек между нодами может сломать leader election.
   - TLS-сертификаты имеют поля NotBefore/NotAfter: если время сильно уехало,
     API-сервер отклонит запросы с ошибкой certificate expired.
   - Метрики и логи становятся бессмысленными без общей временной шкалы. #}

{% for server in ntp_servers %}
{# pool + iburst: "pool" разрешает несколько IP из одного DNS-имени (пул серверов).
   iburst: при первом старте отправляет пачку запросов для быстрой начальной синхронизации
   (иначе первая синхронизация может занять несколько минут). #}
pool {{ server }} iburst
{% endfor %}

{# driftfile: chrony сохраняет сюда вычисленный drift (уход часов в секунду).
   При следующем старте он загружает это значение и сразу компенсирует дрейф,
   не дожидаясь нескольких циклов синхронизации. #}
driftfile /var/lib/chrony/drift

{# makestep 1.0 3: при первых трёх синхронизациях разрешить "ступенчатый" сдвиг времени
   если расхождение больше 1 секунды. После этого chrony только плавно подгоняет часы.
   Без этого параметра chrony не трогает время если оно уехало больше чем на 1с (безопасно,
   но нода запустится с неправильным временем если VM была выключена). #}
makestep 1.0 3

{# rtcsync: периодически записывает системное время в аппаратные часы RTC.
   Актуально для физических машин; на VM RTC управляется гипервизором. #}
rtcsync

{# logdir: директория для логов chrony (статистика синхронизации, tracking). #}
logdir /var/log/chrony
